# 複製這個檔案成 .env，填入你自己的值
# NEVER commit .env to git

# ── n8n 基本設定 ──────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# ── LLM 後端（每個人填自己機器的設定）────────────────────
# Mac M1/M2/M3 用 LM Studio + MLX：
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_MODEL=mlx-community/Llama-3.2-3B-Instruct-4bit

# Windows 用 LM Studio（改成你在 LM Studio 裡載入的模型名）：
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_MODEL=llama-3.2-3b-instruct

# 改用 Ollama 的話：
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3.2

# ── 知識萃取 workflow ──────────────────────────────────────
# 填你自己的名字，筆記的 author 欄位會用這個
AUTHOR_NAME=yourname

# ── notes-to-podcast workflow（選填）────────────────────────
CLAUDE_API_KEY=sk-ant-...
TTS_API_KEY=
TTS_API_URL=https://api.elevenlabs.io/v1/text-to-speech/YOUR_VOICE_ID
